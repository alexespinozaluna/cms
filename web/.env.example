# Copiar a .env.local y ajustar
CONTENT_API_URL=http://localhost:5080
NEXT_PUBLIC_CONTENT_API_URL=http://localhost:5080

# Identidad de la instancia (marca del retail que usa el CMS)
NEXT_PUBLIC_SITE_NAME=MiPortal
# Parte del nombre que se resalta en color en el logo (opcional, vacío = sin acento)
NEXT_PUBLIC_SITE_NAME_ACCENT=Portal
NEXT_PUBLIC_SITE_SLOGAN=Nombre institucional de la organización
NEXT_PUBLIC_SITE_DESCRIPTION=Descripción del sitio para buscadores.
